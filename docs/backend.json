{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Profilo utente con RBAC a 4 livelli per AD next lab.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ruolo": { "type": "string", "enum": ["super_admin", "operatore", "referente", "collaboratore"] },
        "cliente_id": { "type": "string" },
        "nomeAzienda": { "type": "string" },
        "permessi": { "type": "array", "items": { "type": "string" } },
        "creatoIl": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "ruolo"]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Azienda cliente con gestione crediti.",
      "properties": {
        "id": { "type": "string" },
        "nome_azienda": { "type": "string" },
        "settore": { "type": "string" },
        "post_totali": { "type": "number" },
        "post_usati": { "type": "number" },
        "richiesta_upgrade": { "type": "boolean" }
      },
      "required": ["id", "nome_azienda", "post_totali"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Post social con workflow a 7 stati e versioning.",
      "properties": {
        "id": { "type": "string" },
        "titolo": { "type": "string" },
        "testo": { "type": "string" },
        "stato": { "type": "string", "enum": ["bozza", "revisione_interna", "da_approvare", "revisione", "approvato", "programmato", "pubblicato"] },
        "piattaforma": { "type": "string" },
        "formato": { "type": "string" },
        "versione_corrente": { "type": "number" }
      },
      "required": ["id", "titolo", "testo", "stato"]
    },
    "Notifica": {
      "title": "Notifica",
      "type": "object",
      "description": "Evento real-time di sistema.",
      "properties": {
        "id": { "type": "string" },
        "tipo": { "type": "string" },
        "messaggio": { "type": "string" },
        "destinatario_uid": { "type": "string" },
        "letta": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "users/{uid}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Dati utente e permessi."
    },
    "clienti/{clienteId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Dati principali del cliente."
    },
    "clienti/{clienteId}/post/{postId}": {
      "schema": { "$ref": "#/backend/entities/Post" },
      "description": "Contenuti del PED."
    },
    "notifiche/{notificaId}": {
      "schema": { "$ref": "#/backend/entities/Notifica" },
      "description": "Notifiche utente."
    }
  }
}