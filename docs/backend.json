{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Nexus Pro app.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ruolo": { "type": "string", "enum": ["super_admin", "operatore", "referente", "collaboratore"] },
        "cliente_id": { "type": "string", "description": "Tenant ID for multi-tenancy" },
        "nomeAzienda": { "type": "string" },
        "permessi": { "type": "array", "items": { "type": "string" } },
        "creatoIl": { "type": "string", "format": "date-time" },
        "ultimo_accesso": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "nome_azienda": { "type": "string" },
        "settore": { "type": "string" },
        "logo_url": { "type": "string", "description": "Dynamic branding logo" },
        "post_totali": { "type": "number" },
        "post_usati": { "type": "number" },
        "include_business_plan": { "type": "boolean" },
        "include_business_model": { "type": "boolean" },
        "richiesta_upgrade": { "type": "boolean" },
        "richiesta_attenzione": { "type": "boolean", "description": "Triggered when client requests changes" },
        "creato_il": { "type": "string", "format": "date-time" },
        "aggiornato_il": { "type": "string", "format": "date-time" }
      }
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "titolo": { "type": "string" },
        "testo": { "type": "string" },
        "stato": { "type": "string", "enum": ["bozza", "revisione_interna", "da_approvare", "revisione", "approvato", "programmato", "pubblicato"] },
        "piattaforma": { "type": "string" },
        "formato": { "type": "string" },
        "materiale_id": { "type": "string", "description": "ID reference to the associated material" },
        "tipo_pianificazione": { "type": "string", "enum": ["immediata", "programmata"] },
        "scadenza_approvazione": { "type": "string", "format": "date-time", "description": "Deadline for Silenzio Assenso (24h)" },
        "data_pubblicazione": { "type": "string", "format": "date-time" },
        "creato_il": { "type": "string", "format": "date-time" },
        "aggiornato_il": { "type": "string", "format": "date-time" },
        "versione_corrente": { "type": "number" },
        "storico_stati": { "type": "array", "items": { "type": "object" } },
        "versioni": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Material": {
      "title": "Material",
      "type": "object",
      "properties": {
        "nome_file": { "type": "string" },
        "url_storage": { "type": "string" },
        "link_esterno": { "type": "string" },
        "caricato_da": { "type": "string" },
        "ruolo_caricatore": { "type": "string", "enum": ["admin", "cliente"] },
        "stato_validazione": { "type": "string", "enum": ["in_attesa", "validato", "rifiutato"] },
        "destinazione": { "type": "string", "enum": ["social", "sito", "offline", "strategico"] },
        "tipo_strategico": { "type": "string" },
        "note_rifiuto": { "type": "string" },
        "note_cliente": { "type": "string" },
        "creato_il": { "type": "string", "format": "date-time" }
      }
    },
    "Notifica": {
      "title": "Notifica",
      "type": "object",
      "properties": {
        "tipo": { "type": "string" },
        "messaggio": { "type": "string" },
        "destinatario_uid": { "type": "string" },
        "cliente_id": { "type": "string" },
        "riferimento_tipo": { "type": "string", "enum": ["post", "materiale", "cliente", "commento"] },
        "riferimento_id": { "type": "string" },
        "letta": { "type": "boolean" },
        "creato_il": { "type": "string", "format": "date-time" },
        "letta_il": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/users/{uid}/notifiche/{notificaId}": { "schema": "Notifica", "description": "Personal notification log" },
    "/clienti/{clienteId}": { "schema": "Client", "description": "Main tenant data" },
    "/clienti/{clienteId}/post/{postId}": { "schema": "Post", "description": "Content workflow and social posts" },
    "/clienti/{clienteId}/materiali/{materialeId}": { "schema": "Material", "description": "Creative assets and strategic docs" },
    "/clienti/{clienteId}/post/{postId}/commenti/{commentoId}": { "schema": "object", "description": "Contextual chat for each post" }
  }
}