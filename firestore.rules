rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════╗
    // ║          FUNZIONI HELPER                  ║
    // ╚══════════════════════════════════════════╝

    function isAuthenticated() {
      return request.auth != null;
    }

    // Legge il ruolo in modo sicuro: prioritizza i claims, poi Firestore, poi fallback 'guest'
    function getUserRole() {
      return !isAuthenticated() ? 'guest' : (
        request.auth.token.ruolo != null
          ? request.auth.token.ruolo
          : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
              ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ruolo
              : 'guest')
      );
    }

    function getClienteId() {
      return !isAuthenticated() ? null : (
        request.auth.token.cliente_id != null
          ? request.auth.token.cliente_id
          : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
              ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cliente_id
              : null)
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'emanueleadelini@gmail.com' ||
        getUserRole() == 'super_admin' || 
        getUserRole() == 'admin'
      );
    }

    function isAgency() {
      // Evitiamo variabili let per compatibilità e usiamo logica short-circuit
      return isSuperAdmin() || getUserRole() == 'operatore';
    }

    function isClienteOwner(clienteId) {
      return isAuthenticated() && getClienteId() == clienteId;
    }

    // ╔══════════════════════════════════════════╗
    // ║              USERS                        ║
    // ╚══════════════════════════════════════════╝

    match /users/{uid} {
      allow get: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAgency() || (request.auth.uid == uid 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ruolo', 'permessi', 'cliente_id']));
      allow delete: if isSuperAdmin();
    }

    // ╔══════════════════════════════════════════╗
    // ║             CLIENTI                       ║
    // ╚══════════════════════════════════════════╝

    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create: if isAgency(); 
      allow update: if isAgency() || (isClienteOwner(clienteId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['richiesta_upgrade']));
      allow delete: if isSuperAdmin();

      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && getUserRole() in ['referente', 'super_admin']);
        allow delete: if isAgency();

        match /commenti/{commentoId} {
          allow read: if isAgency() || isClienteOwner(clienteId);
          allow create: if isAuthenticated();
          allow update: if isAgency();
          allow delete: if isSuperAdmin();
        }
      }

      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency() || isClienteOwner(clienteId);
        allow delete: if isAgency();
      }
    }

    // ╔══════════════════════════════════════════╗
    // ║            NOTIFICHE                      ║
    // ╚══════════════════════════════════════════╝

    match /notifiche/{notificaId} {
      // List e Get permessi se l'utente è destinatario o agenzia
      allow list, get: if isAuthenticated() && (
        isAgency() || 
        (resource != null && resource.data.destinatario_uid == request.auth.uid)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
  }
}