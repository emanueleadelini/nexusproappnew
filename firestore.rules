rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS AGENCY SECURITY RULES - v10.4
     * 
     * CORE PHILOSOPHY:
     * Protezione multi-tenant con isolamento dei dati per cliente.
     * Accesso garantito ai proprietari dei dati e agli amministratori.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToClient(clientId) {
      return isSignedIn() && (getUserData().cliente_id == clientId || getUserData().clientId == clientId);
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /** Profilo Utente e Notifiche Personali */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Regole per le notifiche dell'utente
      match /notifiche/{notificaId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn(); // Permette a un utente di inviare notifiche a un altro (es. cliente -> admin)
        allow update: if isOwner(userId) || isAdmin(); // Per segnare come letta
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    /** Marker per Amministratori */
    match /admins/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false; 
    }

    /** Clienti (Tenant) */
    match /clienti/{clientId} {
      allow get: if belongsToClient(clientId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      // Post e relativi Commenti
      match /post/{postId} {
        allow get, list: if belongsToClient(clientId) || isAdmin();
        allow create: if isAdmin();
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin();

        match /commenti/{commentoId} {
          allow get, list: if belongsToClient(clientId) || isAdmin();
          allow create: if belongsToClient(clientId) || isAdmin();
          allow update: if isAdmin() || (belongsToClient(clientId) && resource.data.autore_uid == request.auth.uid);
          allow delete: if isAdmin();
        }
      }

      // Asset e Materiali
      match /materiali/{materialId} {
        allow get, list: if belongsToClient(clientId) || isAdmin();
        allow create: if isAdmin() || belongsToClient(clientId);
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin() || (belongsToClient(clientId) && resource.data.uploadedByUserId == request.auth.uid);
      }
    }
  }
}