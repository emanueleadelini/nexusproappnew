rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════╗
    // ║          FUNZIONI HELPER                  ║
    // ╚══════════════════════════════════════════╝

    function isAuthenticated() {
      return request.auth != null;
    }

    // Fallback: se il ruolo non è nel token, lo legge dal documento users
    function getUserRole() {
      return request.auth.token.ruolo != null
        ? request.auth.token.ruolo
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ruolo;
    }

    function getClienteId() {
      return request.auth.token.cliente_id != null
        ? request.auth.token.cliente_id
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cliente_id;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'emanueleadelini@gmail.com' || 
        getUserRole() == 'super_admin'
      );
    }

    function isOperatore() {
      return isAuthenticated() && getUserRole() == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isReferente() {
      return isAuthenticated() && getUserRole() == 'referente';
    }

    function isCollaboratore() {
      return isAuthenticated() && getUserRole() == 'collaboratore';
    }

    function isCliente() {
      return isReferente() || isCollaboratore();
    }

    function isClienteOwner(clienteId) {
      return isCliente() && getClienteId() == clienteId;
    }

    // ╔══════════════════════════════════════════╗
    // ║              USERS                        ║
    // ╚══════════════════════════════════════════╝

    match /users/{uid} {
      allow get: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isSuperAdmin() || (request.auth.uid == uid 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ruolo', 'permessi', 'cliente_id']));
      allow delete: if isSuperAdmin();
    }

    // ╔══════════════════════════════════════════╗
    // ║             CLIENTI                       ║
    // ╚══════════════════════════════════════════╝

    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isOperatore() || isClienteOwner(clienteId);

      // ── POST ──
      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && isReferente());
        allow delete: if isAgency();

        // ── COMMENTI ──
        match /commenti/{commentoId} {
          allow read: if isAgency() || isClienteOwner(clienteId);
          allow create: if isAuthenticated();
          allow update: if isAgency();
          allow delete: if isSuperAdmin();
        }
      }

      // ── MATERIALI ──
      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency() || isClienteOwner(clienteId);
        allow delete: if isAgency();
      }

      // ── CAMPAGNE ──
      match /campagne/{campagnaId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow write: if isAgency();
      }
    }

    // ╔══════════════════════════════════════════╗
    // ║            NOTIFICHE                      ║
    // ╚══════════════════════════════════════════╝

    match /notifiche/{notificaId} {
      allow get: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow list: if isAuthenticated() && (isAgency() || request.query.limit <= 20);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
  }
}