rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════╗
    // ║          FUNZIONI HELPER                  ║
    // ╚══════════════════════════════════════════╝

    function isAuthenticated() {
      return request.auth != null;
    }

    // Controllo rapido via Token (senza letture DB) per prevenire ricorsione
    function isAdminByToken() {
      return isAuthenticated() && (
        request.auth.token.email == 'emanueleadelini@gmail.com' || 
        request.auth.token.ruolo == 'super_admin'
      );
    }

    function isAgencyByToken() {
      return isAdminByToken() || request.auth.token.ruolo == 'operatore';
    }

    // Lettura ruolo dal documento (fallback se claims non pronti)
    function getUserRole() {
      return request.auth.token.ruolo != null
        ? request.auth.token.ruolo
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ruolo;
    }

    function getClienteId() {
      return request.auth.token.cliente_id != null
        ? request.auth.token.cliente_id
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cliente_id;
    }

    function isSuperAdmin() {
      return isAdminByToken() || (isAuthenticated() && getUserRole() == 'super_admin');
    }

    function isAgency() {
      return isAgencyByToken() || (isAuthenticated() && getUserRole() in ['super_admin', 'operatore']);
    }

    function isClienteOwner(clienteId) {
      return isAuthenticated() && getClienteId() == clienteId;
    }

    // ╔══════════════════════════════════════════╗
    // ║              USERS                        ║
    // ╚══════════════════════════════════════════╝

    match /users/{uid} {
      allow get: if isAuthenticated() && (request.auth.uid == uid || isAdminByToken());
      allow list: if isAdminByToken();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAdminByToken() || (request.auth.uid == uid 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ruolo', 'permessi', 'cliente_id']));
      allow delete: if isAdminByToken();
    }

    // ╔══════════════════════════════════════════╗
    // ║             CLIENTI                       ║
    // ╚══════════════════════════════════════════╝

    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isAgency() || isClienteOwner(clienteId);

      // ── POST ──
      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && getUserRole() == 'referente');
        allow delete: if isAgency();

        // ── COMMENTI ──
        match /commenti/{commentoId} {
          allow read: if isAgency() || isClienteOwner(clienteId);
          allow create: if isAuthenticated();
          allow update: if isAgency();
          allow delete: if isSuperAdmin();
        }
      }

      // ── MATERIALI ──
      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency() || isClienteOwner(clienteId);
        allow delete: if isAgency();
      }

      // ── CAMPAGNE ──
      match /campagne/{campagnaId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow write: if isAgency();
      }
      
      // ── BRAND BRIEF ──
      match /brand_brief/{docId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow write: if isAgency();
      }
    }

    // ╔══════════════════════════════════════════╗
    // ║            NOTIFICHE                      ║
    // ╚══════════════════════════════════════════╝

    match /notifiche/{notificaId} {
      // Regola list semplificata per evitare errori di valutazione resource.data
      allow list: if isAuthenticated(); 
      allow get: if isAuthenticated() && (isAgencyByToken() || resource.data.destinatario_uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAgencyByToken() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isAdminByToken();
    }
  }
}