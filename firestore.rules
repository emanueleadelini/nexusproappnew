rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════╗
    // ║          FUNZIONI HELPER                  ║
    // ╚══════════════════════════════════════════╝

    function isAuthenticated() {
      return request.auth != null;
    }

    // Legge il ruolo dai custom claims (priorità) o dal documento user (fallback)
    function getUserRole() {
      return isAuthenticated() && (request.auth.token.ruolo != null
        ? request.auth.token.ruolo
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ruolo);
    }

    function getClienteId() {
      return isAuthenticated() && (request.auth.token.cliente_id != null
        ? request.auth.token.cliente_id
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cliente_id);
    }

    function isSuperAdmin() {
      return getUserRole() == 'super_admin' || getUserRole() == 'admin';
    }

    function isAgency() {
      return getUserRole() in ['super_admin', 'operatore', 'admin'];
    }

    function isClienteOwner(clienteId) {
      return getClienteId() == clienteId;
    }

    // ╔══════════════════════════════════════════╗
    // ║              USERS                        ║
    // ╚══════════════════════════════════════════╝

    match /users/{uid} {
      allow get: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAgency() || (request.auth.uid == uid 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ruolo', 'permessi', 'cliente_id']));
      allow delete: if isSuperAdmin();
    }

    // ╔══════════════════════════════════════════╗
    // ║             CLIENTI                       ║
    // ╚══════════════════════════════════════════╝

    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create, delete: if isSuperAdmin();
      allow update: if isAgency() || isClienteOwner(clienteId);

      // ── POST ──
      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && getUserRole() in ['referente', 'super_admin']);
        allow delete: if isAgency();

        // ── COMMENTI ──
        match /commenti/{commentoId} {
          allow read: if isAgency() || isClienteOwner(clienteId);
          allow create: if isAuthenticated();
          allow update: if isAgency();
          allow delete: if isSuperAdmin();
        }
      }

      // ── MATERIALI ──
      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency() || isClienteOwner(clienteId);
        allow delete: if isAgency();
      }

      // ── CAMPAGNE ──
      match /campagne/{campagnaId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow write: if isAgency();
      }
    }

    // ╔══════════════════════════════════════════╗
    // ║            NOTIFICHE                      ║
    // ╚══════════════════════════════════════════╝

    match /notifiche/{notificaId} {
      allow list: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow get: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
  }
}