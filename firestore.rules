rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS PRO DEFINITIVE RULES V5.8
     * Supporto per Collection Group, Multi-tenancy e Identity-Aware Gating.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"ruolo": "nessuno"};
    }

    function isSuperAdmin() {
      return isSignedIn() && (getUserData().ruolo == 'super_admin' || getUserData().ruolo == 'admin');
    }

    function isOperatore() {
      return isSignedIn() && getUserData().ruolo == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isReferente(clientId) {
      let data = getUserData();
      return isSignedIn() && data.ruolo == 'referente' && data.cliente_id == clientId;
    }

    function isCollaboratore(clientId) {
      let data = getUserData();
      return isSignedIn() && data.ruolo == 'collaboratore' && data.cliente_id == clientId;
    }

    function isClient(clientId) {
      return isReferente(clientId) || isCollaboratore(clientId);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES (Necessarie per Dashboard Admin) ---
    
    match /{path=**}/post/{postId} {
      allow list: if isAgency();
    }

    match /{path=**}/notifiche/{notificaId} {
      allow list: if isAgency();
    }

    // --- STANDARD RULES ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAgency();
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (isOwner(uid) && request.resource.data.ruolo == resource.data.ruolo) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /notifiche/{notificaId} {
        allow read: if isOwner(uid) || isAgency();
        allow create: if isSignedIn(); 
        allow update: if isOwner(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['letta', 'letta_il']);
        allow delete: if isAgency();
      }
    }

    match /clienti/{clienteId} {
      allow get: if isClient(clienteId) || isAgency();
      allow list: if isAgency();
      allow create, update, delete: if isSuperAdmin();

      match /post/{postId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isAgency();
        allow update: if isAgency() || 
          (isReferente(clienteId) && 
           resource.data.stato == 'da_approvare' && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato', 'storico_stati', 'aggiornato_il']));
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isClient(clienteId) || isAgency();
        }
      }

      match /materiali/{materialeId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isClient(clienteId) || isAgency();
        allow update: if isAgency() || (isReferente(clientId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato_validazione', 'note_rifiuto']));
        allow delete: if isAgency();
      }
    }
  }
}
