rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNZIONI HELPER ===
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getAuthProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? getAuthProfile().data.ruolo 
        : 'none';
    }

    function isAdminEmail() {
      return request.auth.token.email == 'emanueleadelini@gmail.com';
    }

    function isSuperAdmin() {
      return isAuthenticated() && (isAdminEmail() || getUserRole() == 'super_admin');
    }

    function isOperatore() {
      return isAuthenticated() && getUserRole() == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isClienteOwner(clienteId) {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getAuthProfile().data.cliente_id == clienteId) ||
        (request.auth.token.cliente_id == clienteId)
      );
    }

    function isReferente() {
      return isAuthenticated() && getUserRole() == 'referente';
    }

    // === USERS ===
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      // Permettiamo la creazione del proprio profilo per il setup iniziale
      allow create: if isAuthenticated() && request.auth.uid == uid;
      // Impediamo la modifica del ruolo a se stessi se non si è Super Admin
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ruolo', 'permessi', 'cliente_id']))
      );
      allow delete: if isSuperAdmin();
    }

    // === CLIENTI ===
    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isOperatore() || isClienteOwner(clienteId);

      // POST
      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && isReferente());
        allow delete: if isAgency();
        
        // COMMENTI
        match /commenti/{commentoId} {
          allow read: if isAgency() || isClienteOwner(clienteId);
          allow create: if isAuthenticated();
          allow update: if isAgency();
          allow delete: if isSuperAdmin();
        }
      }

      // MATERIALI
      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency() || isClienteOwner(clienteId);
        allow delete: if isAgency();
      }

      // CAMPAGNE
      match /campagne/{campagnaId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow write: if isAgency();
      }
    }

    // === NOTIFICHE ===
    match /notifiche/{notificaId} {
      // Split read in get e list per maggiore precisione
      allow get: if isAuthenticated() && (
        isAgency() || 
        resource.data.destinatario_uid == request.auth.uid
      );
      allow list: if isAuthenticated() && (
        isAgency() || 
        request.query.limit <= 20 // Enforce limit per sicurezza
      );
      allow create: if isAuthenticated(); 
      allow update: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
  }
}