rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function getUserRole() {
      let data = getUserData();
      return data != null ? data.ruolo : null;
    }

    function getUserClienteId() {
      let data = getUserData();
      return data != null ? data.cliente_id : null;
    }

    function isAgency() {
      let role = getUserRole();
      return isSignedIn() && (role == 'super_admin' || role == 'admin' || role == 'operatore' || request.auth.token.email == 'emanueleadelini@gmail.com');
    }

    function isClientOf(clienteId) {
      return isSignedIn() && getUserClienteId() == clienteId;
    }

    // --- USERS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (request.auth.uid == uid) || isAgency();
      allow delete: if isAgency();

      match /notifiche/{notificaId} {
        allow read: if request.auth.uid == uid || isAgency();
        allow create: if isSignedIn();
        allow update: if request.auth.uid == uid;
        allow delete: if isAgency();
      }
    }

    // --- CLIENTI ---
    match /clienti/{clienteId} {
      allow get: if isAgency() || isClientOf(clienteId);
      allow list: if isAgency();
      allow create, update, delete: if isAgency();

      match /post/{postId} {
        // La regola list deve essere estremamente robusta
        allow get, list: if isAgency() || isClientOf(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClientOf(clienteId) && resource.data.stato == 'da_approvare');
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isAgency() || isClientOf(clienteId);
        }
      }

      match /materiali/{materialeId} {
        allow get, list: if isAgency() || isClientOf(clienteId);
        allow create: if isAgency() || isClientOf(clienteId);
        allow update: if isAgency() || isClientOf(clienteId);
        allow delete: if isAgency();
      }
    }
  }
}