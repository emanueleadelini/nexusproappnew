rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS AGENCY SECURITY RULES - v10.7
     * 
     * CORE PHILOSOPHY:
     * Protezione multi-tenant con isolamento dei dati per cliente.
     * Accesso privilegiato per il Super Admin emanueleadelini@gmail.com.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "emanueleadelini@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToClient(clientId) {
      // Otteniamo il clientId dal profilo utente per validare l'appartenenza al tenant
      let userProfile = getUserData();
      return isSignedIn() && (
        userProfile.cliente_id == clientId || 
        userProfile.clientId == clientId
      );
    }

    // --- Collection Rules ---

    /** Profilo Utente e Notifiche Personali */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Regole per le notifiche dell'utente
      match /notifiche/{notificaId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    /** Marker per Amministratori */
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Permette la creazione iniziale per il Super Admin specifico
      allow create, update: if isOwner(adminId) && (request.auth.token.email == "emanueleadelini@gmail.com" || isAdmin());
      allow delete: if isAdmin(); 
    }

    /** Clienti (Tenant) */
    match /clienti/{clientId} {
      allow get: if isAdmin() || belongsToClient(clientId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      // Post e relativi Commenti
      match /post/{postId} {
        allow get, list: if isAdmin() || belongsToClient(clientId);
        allow create: if isAdmin();
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin();

        match /commenti/{commentoId} {
          allow get, list: if isAdmin() || belongsToClient(clientId);
          allow create: if isAdmin() || belongsToClient(clientId);
          allow update: if isAdmin() || (belongsToClient(clientId) && resource.data.autore_uid == request.auth.uid);
          allow delete: if isAdmin();
        }
      }

      // Asset e Materiali
      match /materiali/{materialId} {
        allow get, list: if isAdmin() || belongsToClient(clientId);
        allow create: if isAdmin() || belongsToClient(clientId);
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin() || (belongsToClient(clientId) && resource.data.uploadedByUserId == request.auth.uid);
      }
    }

    /** 
     * Supporto per Collection Group Queries (CRITICO)
     * Permette alla Dashboard Admin di interrogare post e materiali globalmente
     */
    match /{path=**}/post/{postId} {
      allow read: if isAdmin();
    }
    
    match /{path=**}/materiali/{materialId} {
      allow read: if isAdmin();
    }

    match /{path=**}/notifiche/{notificaId} {
      allow read: if isAdmin();
    }
  }
}