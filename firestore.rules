rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS PRO RULES V5.2 (SaaS Ready)
     * Robust multi-tenant RBAC with granular subcollection control.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().ruolo == 'super_admin';
    }

    function isOperatore() {
      return isSignedIn() && getUserData().ruolo == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isReferente(clientId) {
      return isSignedIn() && getUserData().ruolo == 'referente' && getUserData().cliente_id == clientId;
    }

    function isCollaboratore(clientId) {
      return isSignedIn() && getUserData().ruolo == 'collaboratore' && getUserData().cliente_id == clientId;
    }

    function isClient(clientId) {
      return isReferente(clientId) || isCollaboratore(clientId);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RULES ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAgency();
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (isOwner(uid) && request.resource.data.ruolo == resource.data.ruolo) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /clienti/{clienteId} {
      allow get: if isClient(clienteId) || isAgency();
      allow list: if isAgency();
      allow create, update, delete: if isSuperAdmin();

      match /post/{postId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isAgency();
        
        // Workflow di approvazione: il referente può SOLO cambiare lo stato e loggare la transizione
        allow update: if isAgency() || 
          (isReferente(clienteId) && 
           resource.data.stato == 'da_approvare' && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato', 'storico_stati', 'aggiornato_il']));
        
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isClient(clienteId) || isAgency();
        }
      }

      match /materiali/{materialeId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isClient(clienteId) || isAgency();
        allow update: if isAgency() || (isReferente(clienteId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato_validazione', 'note_rifiuto']));
        allow delete: if isAgency();
      }
    }

    match /notifiche/{notificaId} {
      // Permette il listato se filtrato per destinatario o se l'utente è dell'agenzia
      allow list: if isSignedIn() && (request.query.filters.destinatario_uid == request.auth.uid || isAgency());
      allow get: if isSignedIn() && (resource.data.destinatario_uid == request.auth.uid || isAgency());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.destinatario_uid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['letta', 'letta_il']);
      allow delete: if isAgency();
    }
  }
}