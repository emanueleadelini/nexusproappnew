rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════╗
    // ║          FUNZIONI HELPER                  ║
    // ╚══════════════════════════════════════════╝

    function isAuthenticated() {
      return request.auth != null;
    }

    // ✅ V4: Hardcoded Admin con check diretto (massima priorità)
    function isHardcodedAdmin() {
      return isAuthenticated() && request.auth.uid == 'DaRQQ7aTpnbw195PmvTE98F2kwD2';
    }

    // Legge il ruolo dai custom claims o dal documento user (fallback)
    function getUserRole() {
      return request.auth.token.ruolo != null
        ? request.auth.token.ruolo
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ruolo
            : 'guest');
    }

    function getClienteId() {
      return request.auth.token.cliente_id != null
        ? request.auth.token.cliente_id
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cliente_id
            : null);
    }

    function isSuperAdmin() {
      return isHardcodedAdmin() || getUserRole() == 'super_admin' || getUserRole() == 'admin';
    }

    function isAgency() {
      return isHardcodedAdmin() || getUserRole() in ['super_admin', 'operatore', 'admin'];
    }

    function isClienteOwner(clienteId) {
      return getClienteId() == clienteId;
    }

    // ╔══════════════════════════════════════════╗
    // ║              USERS                        ║
    // ╚══════════════════════════════════════════╝

    match /users/{uid} {
      allow get: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      allow list: if isAuthenticated() && isAgency();
      allow create: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
      allow update: if isAuthenticated() && (isAgency() || (request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ruolo', 'permessi', 'cliente_id'])));
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ╔══════════════════════════════════════════╗
    // ║             CLIENTI                       ║
    // ╚══════════════════════════════════════════╝

    match /clienti/{clienteId} {
      allow get: if isAuthenticated() && (isAgency() || isClienteOwner(clienteId));
      allow list: if isAuthenticated() && isAgency();
      allow create: if isAuthenticated() && isAgency();
      allow update: if isAuthenticated() && (isAgency() || (isClienteOwner(clienteId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['richiesta_upgrade'])));
      allow delete: if isAuthenticated() && isSuperAdmin();

      // ── POST ──
      match /post/{postId} {
        allow read: if isAuthenticated() && (isAgency() || isClienteOwner(clienteId));
        allow create: if isAuthenticated() && isAgency();
        allow update: if isAuthenticated() && (isAgency() || (isClienteOwner(clienteId) && getUserRole() in ['referente', 'super_admin']));
        allow delete: if isAuthenticated() && isAgency();

        // ── COMMENTI ──
        match /commenti/{commentoId} {
          allow read: if isAuthenticated() && (isAgency() || isClienteOwner(clienteId));
          allow create: if isAuthenticated();
          allow update: if isAuthenticated() && isAgency();
          allow delete: if isAuthenticated() && isSuperAdmin();
        }
      }

      // ── MATERIALI ──
      match /materiali/{materialeId} {
        allow read: if isAuthenticated() && (isAgency() || isClienteOwner(clienteId));
        allow create: if isAuthenticated() && (isAgency() || isClienteOwner(clienteId));
        allow update: if isAuthenticated() && (isAgency() || isClienteOwner(clienteId));
        allow delete: if isAuthenticated() && isAgency();
      }
    }

    // ╔══════════════════════════════════════════╗
    // ║            NOTIFICHE                      ║
    // ╚══════════════════════════════════════════╝

    match /notifiche/{notificaId} {
      // ✅ V4: Semplificato il listing per evitare blocchi inutili
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isAuthenticated() && isSuperAdmin();
    }
  }
}