rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a Database-Based Access Control (DBAC) model for the Nexus Agency application.
     * Access is governed by a user's role ('admin' or 'client') and their association with a specific 'Client' entity.
     * 
     * DATA STRUCTURE:
     * - /users/{uid}: Central profile storage. Authentication UID is used as the Document ID.
     * - /clienti/{clienteId}: Top-level agency clients.
     * - /clienti/{clienteId}/post/{postId}: Subcollection for editorial content.
     * - /clienti/{clienteId}/materiali/{materialeId}: Subcollection for digital assets.
     * 
     * KEY SECURITY DECISIONS:
     * - Role Lookup: Since Custom Claims are not used, a `get()` call to the `/users` collection is performed to determine the requester's role and clientId.
     * - Multi-tenancy: Clients are strictly siloed. A user with role 'client' can only access data where the path wildcard `{clienteId}` matches the `clientId` stored in their user profile.
     * - Admin Oversight: Users with the 'admin' role bypass client-level siloing for all collections.
     * - Immutability: Critical relational fields like `clientId` and `uploadedBy` are protected during updates.
     * 
     * PROTOTYPING MODE:
     * Rules focus on authorization and relational integrity (IDs matching paths). Detailed schema validation (types, optional fields) is omitted to allow for rapid development iteration.
     */

    // --- HELPER FUNCTIONS ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Retrieves the user's document from Firestore. */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** Verifies if the authenticated user has the 'admin' role. */
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    /** Verifies if the authenticated user is a client associated with a specific ID. */
    function isClient(targetClientId) {
      return isSignedIn() && getUserData().role == 'client' && getUserData().clientId == targetClientId;
    }

    /** Checks if the user is the owner of the document (based on UID matching ID). */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is the owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Validates that a field is not being changed. */
    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles. Users can manage their own profile; admins can manage everyone.
     * @path /users/{uid}
     * @allow get: if isOwner(uid) || isAdmin();
     * @allow list: if isAdmin();
     * @allow create: if isOwner(uid) || isAdmin();
     * @allow update: if (isOwner(uid) && isUnchanged('role')) || isAdmin();
     * @deny delete: if !isAdmin();
     * @principle Ownership-based access for users, role-based for admins.
     */
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(uid) && request.resource.data.id == uid) || isAdmin();
      allow update: if (isExistingOwner(uid) && isUnchanged('role') && isUnchanged('id')) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for client companies. Clients can read their own company info; admins have full control.
     * @path /clienti/{clienteId}
     * @allow get: if isClient(clienteId) || isAdmin();
     * @allow list: if isAdmin();
     * @allow create: if isAdmin();
     * @allow update: if isAdmin();
     * @allow delete: if isAdmin();
     * @principle Client-siloing for clients, universal access for admins.
     */
    match /clienti/{clienteId} {
      allow get: if isClient(clienteId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Rules for editorial posts. Nested under the parent client.
       * @path /clienti/{clienteId}/post/{postId}
       * @allow read: if isClient(clienteId) || isAdmin();
       * @allow write: if isClient(clienteId) || isAdmin();
       * @principle Path-based authorization matched against user's clientId.
       */
      match /post/{postId} {
        allow get, list: if isClient(clienteId) || isAdmin();
        allow create: if (isClient(clienteId) && request.resource.data.clientId == clienteId) || isAdmin();
        allow update: if (resource != null && (isClient(clienteId) || isAdmin()) && isUnchanged('clientId'));
        allow delete: if (resource != null && (isClient(clienteId) || isAdmin()));
      }

      /**
       * @description Rules for digital materials/assets. Nested under the parent client.
       * @path /clienti/{clienteId}/materiali/{materialeId}
       * @allow read: if isClient(clienteId) || isAdmin();
       * @allow write: if isClient(clienteId) || isAdmin();
       * @principle Ensures uploaded material belongs to the active client and tracks the uploader.
       */
      match /materiali/{materialeId} {
        allow get, list: if isClient(clienteId) || isAdmin();
        allow create: if (isClient(clienteId) && request.resource.data.clientId == clienteId && request.resource.data.uploadedBy == request.auth.uid) || isAdmin();
        allow update: if (resource != null && (isClient(clienteId) || isAdmin()) && isUnchanged('clientId') && isUnchanged('uploadedBy'));
        allow delete: if (resource != null && (isClient(clienteId) || isAdmin()));
      }
    }
  }
}