rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS AGENCY SECURITY RULES - PROTOTYPING PHASE
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a hybrid security model designed for an agency-client relationship.
     * It prioritizes strict authorization (who can access what) while maintaining flexibility 
     * in data structures for rapid prototyping.
     * 
     * DATA STRUCTURE & HIERARCHY:
     * - /users/{userId}: Primary profile storage and authorization context (role, clientId).
     * - /admins/{adminId}: A marker collection for global administrators (Authorization Independence).
     * - /clienti/{clientId}: Top-level organizational units for client companies.
     * - /clienti/{clientId}/post/{postId}: Subcollection for editorial content.
     * - /clienti/{clientId}/materiali/{materialId}: Subcollection for digital assets.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Admin Authorization: Admin status is verified via the existence of a document in the /admins 
     *    collection, avoiding expensive data lookups on every request.
     * 2. Client Scoping: Client users are granted access based on the 'clientId' stored in their 
     *    own UserProfile document.
     * 3. Denormalization for Performance: 'clientId' is mirrored inside subcollection documents 
     *    to allow for single-document authorization checks without traversing parent paths.
     * 4. Query-Aware Security (QAP): List operations on /clienti are restricted to admins to 
     *    prevent client users from discovering other companies.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user is a global administrator via master email, collection existence, or Firestore role. */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'emanueleadelini@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ruolo in ['super_admin', 'admin_agenzia'])
      );
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Retrieves the authenticated user's profile data. */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** Checks if the authenticated user is associated with a specific clientId. */
    function belongsToClient(clientId) {
      return isSignedIn() && getUserData().cliente_id == clientId;
    }

    /** Combines ownership and existence checks for destructive/modifying operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Users manage their own profiles; Admins manage all.
     * @path /users/{userId}
     * @allow get: (read) if the user is the owner or an admin.
     * @deny list: (read) if a user tries to list all user profiles.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isExistingOwner(userId) || isAdmin()) && (!('id' in request.resource.data) || request.resource.data.id == userId);
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for user notifications.
     */
    match /users/{userId}/notifiche/{notificaId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create, delete: if isAdmin();
    }

    /**
     * @description Rules for the admin marker collection. Strictly controlled for security.
     * @path /admins/{adminId}
     * @allow get: (read) if the user is an admin.
     * @deny create: (write) if a non-admin tries to promote themselves.
     * @principle Implements DBAC (Database-Based Access Control) for high-privilege roles.
     */
    match /admins/{adminId} {
      allow get, list: if isAdmin() || request.auth.uid == adminId;
      allow create, update, delete: if request.auth.token.email == 'emanueleadelini@gmail.com'; // Temporaneo bypass per il fondatore
    }

    /**
     * @description Rules for Client entities. Admins have full access; Clients see only their own company.
     * @path /clienti/{clientId}
     * @allow get: (read) if the user belongs to this client.
     * @deny list: (read) for client users to prevent cross-company discovery.
     * @principle Path-based scoping for client privacy.
     */
    match /clienti/{clientId} {
      allow get: if belongsToClient(clientId) || isAdmin();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      // Admin: update completo. Cliente: può segnalare solo richiesta_attenzione e richiesta_upgrade sul proprio doc.
      allow update: if isAdmin() || (
        belongsToClient(clientId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['richiesta_attenzione', 'richiesta_upgrade'])
      );
    }

    /**
     * @description Rules for Posts. Clients can read/list their own and update status to 'approvato'.
     * @path /clienti/{clientId}/post/{postId}
     * @allow list: (read) if the client ID in the path matches the user's client ID.
     * @deny update: (write) if a client tries to change the clientId association.
     * @principle Enforces relational integrity and client-scoped visibility.
     */
    /**
     * @description Regola per collection group queries (dashboard admin).
     * Il wildcard ricorsivo {path=**} è obbligatorio per collectionGroup().
     * La condizione è scritta inline per evitare problemi di valutazione delle funzioni
     * nel contesto delle collection group query.
     */
    match /{path=**}/post/{postId} {
      allow list: if isAdmin();
    }

    match /clienti/{clientId}/post/{postId} {
      allow get, list: if belongsToClient(clientId) || isAdmin();
      allow create: if isAdmin();
      allow update: if (resource != null) && (isAdmin() || (belongsToClient(clientId) && (!('clientId' in request.resource.data) || request.resource.data.clientId == resource.data.clientId)));
      allow delete: if isAdmin();

      match /commenti/{commentoId} {
        allow read, create: if belongsToClient(clientId) || isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Rules for Materials. Clients can upload files for their company.
     * @path /clienti/{clientId}/materiali/{materialId}
     * @allow create: (write) if the client ID and uploadedByUserId are correctly set.
     * @deny create: (write) if a user tries to upload materials for a different client.
     * @principle Validates relational consistency between path, user session, and document data.
     */
    /**
     * @description Rules for Support Requests (Richieste). Clients create/read their own; admins manage all.
     * @path /clienti/{clientId}/richieste/{richiestaId}
     */
    match /{path=**}/richieste/{richiestaId} {
      allow list, get: if isAdmin();
    }

    match /clienti/{clientId}/richieste/{richiestaId} {
      allow get, list: if belongsToClient(clientId) || isAdmin();
      allow create: if belongsToClient(clientId) || isAdmin();
      allow update: if isAdmin() || (
        belongsToClient(clientId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['non_letti_cliente', 'aggiornato_il', 'ultimo_messaggio_preview'])
      );
    }

    match /clienti/{clientId}/richieste/{richiestaId}/messaggi/{msgId} {
      allow get, list: if belongsToClient(clientId) || isAdmin();
      allow create: if belongsToClient(clientId) || isAdmin();
    }

    /**
     * @description Rules for public leads from landing page (Prova Nexus Pro / Prova Placeat).
     * @path /leads/{leadId}
     * Anyone can create; only admins can read, update, delete.
     */
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /clienti/{clientId}/materiali/{materialId} {
      allow get, list: if belongsToClient(clientId) || isAdmin();
      // Admin può creare liberamente; il cliente deve rispettare la validazione dei campi
      allow create: if isAdmin() || (
        belongsToClient(clientId) &&
        request.resource.data.clientId == clientId &&
        request.resource.data.uploadedByUserId == request.auth.uid
      );
      allow update: if (resource != null) && (isAdmin() || (belongsToClient(clientId) && (!('clientId' in request.resource.data) || request.resource.data.clientId == resource.data.clientId)));
      allow delete: if (resource != null) && (isAdmin() || (belongsToClient(clientId) && resource.data.uploadedByUserId == request.auth.uid));
    }
  }
}