rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - COMMUNICATION AGENCY MANAGEMENT APP
 * 
 * Core Philosophy:
 * This ruleset implements a strict multi-tenant authorization model.
 * Updated to allow Admins to create user profiles for new clients.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && getAuthProfile().data.ruolo == 'admin';
    }

    function isClientOf(clienteId) {
      return isSignedIn() && getAuthProfile().data.cliente_id == clienteId;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- COLLECTION RULES ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      // Permettiamo la creazione del proprio profilo (bootstrap) o da parte di un admin (creazione clienti)
      allow create: if isOwner(uid) || isAdmin(); 
      allow update, delete: if isAdmin();
    }

    match /clienti/{clienteId} {
      allow get, list: if isAdmin() || isClientOf(clienteId);
      allow create, update, delete: if isAdmin();

      match /post/{postId} {
        allow get, list: if isAdmin() || isClientOf(clienteId);
        allow create, update, delete: if isAdmin();
        // Permettiamo al cliente solo l'approvazione del post
        allow update: if isClientOf(clienteId) && request.resource.data.stato == 'approvato';
      }

      match /materiali/{materialId} {
        allow get, list: if isAdmin() || isClientOf(clienteId);
        allow create: if isAdmin() || isClientOf(clienteId);
        allow update, delete: if isAdmin();
      }
    }
  }
}