{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": [
    {
      "bucket": "ad-next-lab-pro.firebasestorage.app",
      "rules": "storage.rules"
    }
  ],
  "hosting": {
